AddType image/x-icon .ico
AddType image/png .png
AddType image/jpeg .jpg

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTP_HOST} ^www\.matejkadlec\.cz [NC] 
    RewriteRule ^(.*)$ https://matejkadlec.cz/$1 [L,R=301]

    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?matejkadlec\.cz [NC]
    RewriteRule \.(ico|png|jpe?g|gif|webp|svg)$ - [F,L]

    RewriteRule ^favicon\.ico$ /assets/img/favicon/favicon.ico [L]
    RewriteRule ^index(?:\.html)?/?$ / [R=301,L]
    RewriteRule ^o-mne/?$ /about-me.html [NC,L]
    RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
    RewriteRule ^ /%1 [NC,L,R=301]

    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^ %{REQUEST_URI}.html [NC,L]
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/jpeg "access plus 6 months"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "^favicon\.ico$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
</IfModule>
